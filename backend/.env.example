NODE_ENV=development
PORT=5000

# MongoDB connection string
MONGO_URI=mongodb://127.0.0.1:27017/team_task_manager

# JWT
JWT_SECRET=replace-with-a-long-random-string
JWT_EXPIRES_IN=7d

# CORS — comma separated list of allowed origins.
# Supports exact origins and `*.domain.tld` wildcards (helpful for Vercel previews).
# Example: http://localhost:5173,https://stride.vercel.app,https://*.vercel.app
CLIENT_ORIGINS=http://localhost:5173,http://localhost:4173
